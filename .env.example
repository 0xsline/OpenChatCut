# Agent LLMs via Vercel AI SDK. Configure any number of providers independently.
# LLM_PROVIDER only controls the initially selected provider in AI Chat.
LLM_PROVIDER=anthropic

LLM_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
LLM_ANTHROPIC_API_KEY=
LLM_ANTHROPIC_MODEL=claude-fable-5

LLM_OPENAI_BASE_URL=https://api.openai.com/v1
LLM_OPENAI_API_KEY=
LLM_OPENAI_MODEL=gpt-5

LLM_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_GEMINI_API_KEY=
LLM_GEMINI_MODEL=gemini-3.5-flash

LLM_KIMI_BASE_URL=https://api.moonshot.ai/v1
LLM_KIMI_API_KEY=
LLM_KIMI_MODEL=kimi-k3

LLM_QWEN_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
LLM_QWEN_API_KEY=
LLM_QWEN_MODEL=qwen-plus

LLM_GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_GLM_API_KEY=
LLM_GLM_MODEL=glm-5.2

LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com
LLM_DEEPSEEK_API_KEY=
LLM_DEEPSEEK_MODEL=deepseek-v4-pro

LLM_MINIMAX_BASE_URL=https://api.minimaxi.com/v1
LLM_MINIMAX_API_KEY=
LLM_MINIMAX_MODEL=MiniMax-M3

LLM_MISTRAL_BASE_URL=https://api.mistral.ai/v1
LLM_MISTRAL_API_KEY=
LLM_MISTRAL_MODEL=mistral-large-latest

# Any OpenAI-compatible gateway, including a self-hosted or local endpoint.
LLM_OPENAI_COMPATIBLE_BASE_URL=http://127.0.0.1:8317/v1
LLM_OPENAI_COMPATIBLE_API_KEY=
LLM_OPENAI_COMPATIBLE_MODEL=

# Server-only image generation credentials. Never use a VITE_ prefix.
IMAGE_BASE_URL=https://api.openai.com
IMAGE_API_KEY=

GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

ELEVENLABS_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_SOUND_MODEL=eleven_text_to_sound_v2

DOUBAO_TTS_BASE_URL=https://openspeech.bytedance.com
DOUBAO_TTS_APP_ID=
DOUBAO_TTS_ACCESS_KEY=
DOUBAO_TTS_RESOURCE_ID=seed-tts-2.0

MUREKA_BASE_URL=https://api.mureka.ai
MUREKA_API_KEY=
MUREKA_MUSIC_MODEL=auto

SEEDANCE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDANCE_API_KEY=
SEEDANCE_VIDEO_MODEL=doubao-seedance-2-0-260128

KLING_BASE_URL=https://api-singapore.klingai.com
KLING_API_KEY=
KLING_VIDEO_MODEL=kling-v3-omni

# Firecrawl web-browser integration — server-only; never VITE_
# Can also come from shell export (e.g. ~/.claude/secrets/search-apis.env)
FIRECRAWL_API_KEY=

# Stock media (search_stock_media) — any one enables stock capability
PEXELS_API_KEY=
PIXABAY_API_KEY=
UNSPLASH_ACCESS_KEY=
FREESOUND_API_KEY=


# Cloudflare R2 云存储(可选)— 配齐四项后上传写穿 R2,本地磁盘变缓存,缺文件自动回源。
# R2 控制台建桶 → R2 API Token(Object Read & Write)。桶保持私有即可(读取走本地服务回源)。
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# 素材保存目录(可选)— 绝对路径,支持 ~/ 开头;留空 = 默认 public/media/uploads/。
# 改动后老素材自动同步到新目录(原文件保留),工程内路径不变。
MEDIA_DIR=

# 单文件上传上限(字节)。默认 10GiB;本地大视频可按磁盘调整。
# UPLOAD_MAX_BYTES=10737418240
