# Agent LLM. An official Anthropic API key works directly with these defaults.
# Compatible Anthropic Messages API services can override the Base URL and model.
LLM_BASE_URL=https://api.anthropic.com
LLM_API_KEY=
LLM_MODEL=claude-fable-5

# Server-only image generation credentials. Never use a VITE_ prefix.
IMAGE_BASE_URL=https://api.openai.com
IMAGE_API_KEY=

GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

ELEVENLABS_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_SOUND_MODEL=eleven_text_to_sound_v2

DOUBAO_TTS_BASE_URL=https://openspeech.bytedance.com
DOUBAO_TTS_APP_ID=
DOUBAO_TTS_ACCESS_KEY=
DOUBAO_TTS_RESOURCE_ID=seed-tts-2.0

MUREKA_BASE_URL=https://api.mureka.ai
MUREKA_API_KEY=
MUREKA_MUSIC_MODEL=auto

SEEDANCE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDANCE_API_KEY=
SEEDANCE_VIDEO_MODEL=doubao-seedance-2-0-260128

KLING_BASE_URL=https://api-singapore.klingai.com
KLING_API_KEY=
KLING_VIDEO_MODEL=kling-v3-omni

# Firecrawl web-browser integration — server-only; never VITE_
# Can also come from shell export (e.g. ~/.claude/secrets/search-apis.env)
FIRECRAWL_API_KEY=

# Stock media (search_stock_media) — any one enables stock capability
PEXELS_API_KEY=
PIXABAY_API_KEY=
UNSPLASH_ACCESS_KEY=
FREESOUND_API_KEY=


# Cloudflare R2 云存储(可选)— 配齐四项后上传写穿 R2,本地磁盘变缓存,缺文件自动回源。
# R2 控制台建桶 → R2 API Token(Object Read & Write)。桶保持私有即可(读取走本地服务回源)。
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# 素材保存目录(可选)— 绝对路径,支持 ~/ 开头;留空 = 默认 public/media/uploads/。
# 改动后老素材自动同步到新目录(原文件保留),工程内路径不变。
MEDIA_DIR=

# 单文件上传上限(字节)。默认 10GiB;本地大视频可按磁盘调整。
# UPLOAD_MAX_BYTES=10737418240
